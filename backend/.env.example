# Python Backend Configuration for AI Metadata Improvement Tool
# Copy this file to .env and fill in your values

# Socrata API Configuration (required for Socrata open data portal access)
# Register your app via Developer Settings in your data.wa.gov profile
# The App Token is also used as the OAuth client_id
SOCRATA_APP_TOKEN=

# Socrata OAuth 2.0 (optional - enables "Sign in with data.wa.gov" button)
# The Secret Token from your registered app
SOCRATA_SECRET_TOKEN=
# Where data.wa.gov redirects after OAuth login (must match your registered app)
SOCRATA_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/socrata/callback

# Default LLM endpoint (optional - can also be set via UI)
# Works with any OpenAI-compatible API (OpenAI, Azure, HuggingFace, etc.)
# Recommended models: gpt5-mini, gpt5-nano, Qwen3-4B-Instruct-2507, Qwen/Qwen3-8B,
#   mistralai/Ministral-3-8B-Instruct-2512, mistralai/Ministral-3-14B-Instruct-2512
LLM_ENDPOINT=https://api.openai.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=gpt5-mini

# Server Configuration
PORT=8000
CORS_ORIGIN=*

# Frontend URL (for OAuth callback redirect during development)
# Leave empty in production when frontend is served from the same server
FRONTEND_URL=http://localhost:5173
