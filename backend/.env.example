# Python Backend Configuration for AI Metadata Improvement Tool
# Copy this file to .env and fill in your values

# Socrata API Configuration (required for Socrata open data portal access)
# Register your app via Developer Settings in your data.wa.gov profile
# The App Token is also used as the OAuth client_id
SOCRATA_APP_TOKEN=

# Socrata OAuth 2.0 (optional - enables "Sign in with data.wa.gov" button)
# The Secret Token from your registered app
SOCRATA_SECRET_TOKEN=
# Where data.wa.gov redirects after OAuth login (must match your registered app)
SOCRATA_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/socrata/callback

# Cookie flags. Default Secure=true (HTTPS only) + SameSite=Lax (recommended).
# For local dev without HTTPS, set SESSION_COOKIE_SECURE=false (Vite proxy required).
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_SAMESITE=lax

# Session cookie lifetime in seconds. Default 86400 (1 day). Applies to both
# the browser cookie Max-Age and the server-side Fernet TTL check.
# SESSION_COOKIE_MAX_AGE_SECONDS=86400

# Fernet encryption key for the session cookie. Optional.
# If omitted, a fresh key is generated on server start, which invalidates all
# sessions when the app restarts. For production, generate a key with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SESSION_ENCRYPTION_KEY=

# Default LLM endpoint (optional - can also be set via UI)
# Works with any OpenAI-compatible API (OpenAI, Azure, HuggingFace, etc.)
# Recommended models: gpt-5-mini, gpt-5-nano, Qwen3-4B-Instruct-2507, Qwen/Qwen3-8B,
#   mistralai/Ministral-3-8B-Instruct-2512, mistralai/Ministral-3-14B-Instruct-2512
LLM_ENDPOINT=https://api.openai.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-5-mini

# Optional per-mode model overrides. If unset, each mode falls back to LLM_MODEL.
# UI configuration takes priority over these env values.
#   concise  — used when "Regenerate (Concise)" is invoked
#   detailed — used when "Regenerate (Detailed)" is invoked
#   suggest  — used by "Suggest Improvement" calls
# LLM_MODEL_CONCISE=
# LLM_MODEL_DETAILED=
# LLM_MODEL_SUGGEST=

# Dev-mode metadata eval (scripts/eval_viewer.html "Run new eval…" button and
# scripts/evaluate_metadata_quality.ipynb). The POST /api/eval/run endpoint is
# disabled unless ENABLE_EVAL=1 because it spends real LLM tokens.
# JUDGE_LLM_MODEL overrides LLM_MODEL for the judge call only; leave unset to
# use the same model for generation and judging.
# ENABLE_EVAL=1
# JUDGE_LLM_MODEL=

# Server Configuration
PORT=8000
CORS_ORIGIN=*

# Frontend URL (for OAuth callback redirect during development)
# Leave empty in production when frontend is served from the same server
FRONTEND_URL=http://localhost:5173
