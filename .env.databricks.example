# Databricks deployment environment variables
# Copy this file to .env.databricks and fill in your values:
#   cp .env.databricks.example .env.databricks
#
# - VITE_* vars are used at build time by Vite (frontend)
# - All other vars are used at runtime by the Python backend
# - DATABRICKS_APP_NAME and DATABRICKS_WORKSPACE_PATH is used by deploy.sh only

# --- Deployment ---
DATABRICKS_APP_NAME=
DATABRICKS_WORKSPACE_PATH=

# Frontend: use empty string for relative URLs, or set to your Databricks app URL
VITE_API_BASE_URL=

# --- Required ---
SOCRATA_APP_TOKEN=your-socrata-app-token

# --- LLM Configuration (optional - can also be set via app UI) ---
LLM_ENDPOINT=https://your-endpoint.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=your-model-name

# --- Socrata OAuth (optional - for "Sign in with data.wa.gov") ---
SOCRATA_SECRET_TOKEN=your-socrata-secret-token
SOCRATA_OAUTH_REDIRECT_URI=https://your-databricks-app-url/api/auth/socrata/callback
FRONTEND_URL=https://your-databricks-app-url

# Fernet key encrypting the OAuth session cookie. Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required when SOCRATA_SECRET_TOKEN is set. Rotating invalidates all sessions.
SESSION_ENCRYPTION_KEY=
