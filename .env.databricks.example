# Databricks deployment environment variables
# Copy this file to .env.databricks and fill in your values:
#   cp .env.databricks.example .env.databricks
#
# - VITE_* vars are used at build time by Vite (frontend)
# - All other vars are used at runtime by the Python backend
# - DATABRICKS_APP_NAME and DATABRICKS_WORKSPACE_PATH are used by deploy.sh only
# - FRONTEND_URL is the single source of truth for all URL vars — deploy.sh derives the rest

# --- Deployment ---
DATABRICKS_APP_NAME=
DATABRICKS_WORKSPACE_PATH=

# Base URL — set this once, deploy.sh derives VITE_API_BASE_URL and SOCRATA_OAUTH_REDIRECT_URI from it.
# No trailing slash — deploy.sh appends paths directly.
FRONTEND_URL=https://your-databricks-app-url

# Frontend (do not edit — deploy.sh fills this in from FRONTEND_URL)
VITE_API_BASE_URL=__FRONTEND_URL__

# --- Required ---
# The "App Token" from your data.wa.gov app (Profile → Developer Settings).
SOCRATA_APP_TOKEN=your-socrata-app-token

# --- LLM Configuration (optional but recommended) ---
# If unset, each user must enter their own LLM credentials in the app UI on first use.
# Set these to pre-configure the LLM for everyone using the deployed app.
LLM_ENDPOINT=https://your-endpoint.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=your-model-name

# --- Socrata OAuth (optional - for "Sign in with data.wa.gov") ---
# The "Secret Token" from the same data.wa.gov app as SOCRATA_APP_TOKEN above.
SOCRATA_SECRET_TOKEN=your-socrata-secret-token
# (do not edit — deploy.sh fills this in from FRONTEND_URL)
SOCRATA_OAUTH_REDIRECT_URI=__FRONTEND_URL__/api/auth/socrata/callback
